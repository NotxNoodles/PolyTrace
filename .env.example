# ── Database ──────────────────────────────────────────────
# LOCAL (Docker):
# DATABASE_URL=postgresql+asyncpg://polytrace:polytrace@localhost:5432/polytrace
# DATABASE_URL_SYNC=postgresql://polytrace:polytrace@localhost:5432/polytrace
#
# CLOUD (Neon — free, no Docker needed):
# Sign up at https://neon.tech, create a project, copy the connection string.
DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-XXXX.us-east-2.aws.neon.tech/polytrace?ssl=require
DATABASE_URL_SYNC=postgresql://USER:PASS@ep-XXXX.us-east-2.aws.neon.tech/polytrace?ssl=require

# ── Polygon RPC (optional — only for on-chain tracking) ──
POLYGON_RPC_URL=
POLYGON_WS_URL=

# ── Polymarket APIs (public, no key needed) ──────────────
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com

# ── Spot Market APIs ─────────────────────────────────────
BINANCE_API_URL=https://api.binance.com

# ── App Config ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# ── Polling Intervals (seconds) ─────────────────────────
GAMMA_POLL_INTERVAL=300
CLOB_POLL_INTERVAL=60
DATA_API_POLL_INTERVAL=120
SPOT_POLL_INTERVAL=60
HEURISTICS_RUN_INTERVAL=600
ORACLE_RUN_INTERVAL=120
